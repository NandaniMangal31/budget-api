# ---- Server ----
PORT=5000

# ---- MongoDB ----
# Local: mongodb://127.0.0.1:27017/budget-app
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/budget-app
MONGO_URI=mongodb://127.0.0.1:27017/budget-app

# ---- Auth ----
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- OpenAI (used to read + categorize scanned documents) ----
# Get this from https://platform.openai.com/api-keys (see README for full steps)
OPENAI_API_KEY=sk-replace-me
# Leave AI_DISABLED=false to use OpenAI. Set to true to force the free
# rule-based categorizer (useful for testing without burning API credits).
AI_DISABLED=false

# ---- Email alerts (Gmail) ----
# GMAIL_USER must be a real gmail address.
# GMAIL_APP_PASSWORD must be a 16-character App Password (NOT your normal password).
# See README for how to generate one.
GMAIL_USER=youraddress@gmail.com
GMAIL_APP_PASSWORD=replace_with_16_char_app_password

# ---- Frontend origin (for CORS) ----
CLIENT_URL=http://localhost:5173
